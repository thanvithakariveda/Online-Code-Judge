# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas or local
MONGODB_URI=mongodb://localhost:27017/online-code-judge

# JWT secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Judge0 API (RapidAPI or self-hosted)
# RapidAPI: https://rapidapi.com/judge0-official/api/judge0-ce
# Leave JUDGE0_API_KEY empty (or placeholder) to use free https://ce.judge0.com
# Or set a real RapidAPI key for judge0-ce.p.rapidapi.com
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_API_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# Frontend URL(s) for CORS — required in production on Render
# Example: CLIENT_URL=https://online-code-judge-phi.vercel.app
# Multiple: CLIENT_URL=https://app.vercel.app,https://preview.vercel.app
CLIENT_URL=http://localhost:5173,http://localhost:5174
