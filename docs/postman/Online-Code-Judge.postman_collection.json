{
  "info": {
    "name": "Online Code Judge API",
    "description": "REST API for Online Code Judge. Import environment Local or Production.\n\nAfter Login/Register, `token` is saved automatically for protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "problemId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.eql(true));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  pm.environment.set('token', json.data.token);",
                  "}",
                  "pm.test('Has token', () => pm.expect(json.data.token).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  pm.environment.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Problems",
      "item": [
        {
          "name": "List Problems",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/problems?difficulty=&search=",
              "host": ["{{baseUrl}}"],
              "path": ["problems"],
              "query": [
                { "key": "difficulty", "value": "" },
                { "key": "search", "value": "" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.problems && json.data.problems[0]) {",
                  "  pm.collectionVariables.set('problemId', json.data.problems[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Problem By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/problems/{{problemId}}"
          }
        },
        {
          "name": "Create Problem (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hello World\",\n  \"description\": \"Print hello\",\n  \"sampleInput\": \"\",\n  \"sampleOutput\": \"hello\",\n  \"difficulty\": \"Easy\",\n  \"tags\": [\"starter\"],\n  \"hiddenTestCases\": []\n}"
            },
            "url": "{{baseUrl}}/problems"
          }
        },
        {
          "name": "Update Problem (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hello World Updated\",\n  \"description\": \"Print hello world\"\n}"
            },
            "url": "{{baseUrl}}/problems/{{problemId}}"
          }
        },
        {
          "name": "Delete Problem (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/problems/{{problemId}}"
          }
        }
      ]
    },
    {
      "name": "Submissions",
      "item": [
        {
          "name": "Submit Code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"code\": \"print('hello')\",\n  \"language\": \"python\"\n}"
            },
            "url": "{{baseUrl}}/submissions"
          }
        },
        {
          "name": "My Submissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/submissions/me"
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leaderboard?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["leaderboard"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        }
      ]
    },
    {
      "name": "Contests",
      "item": [
        {
          "name": "List Contests",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/contests"
          }
        }
      ]
    }
  ]
}
